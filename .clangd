If:
  # This matches files in the root folder, but NOT files in subdirectories
  # ^/home/albert/proj/buildpp/  -> starts with the root path
  # [^/]+$                      -> ends with a filename that has NO further slashes
  PathMatch: ^./[^/]+$

CompilationDatabase:
  # This tells clangd to stop looking at the compile_commands.json 
  # for any file that matched the pattern above.
  Directory: .

CompileFlags:
  # Optional: add default flags for these "loose" root files
  Add: [-std=c++23, -I/home/albert/proj/buildpp/include]
  # Or Remove everything if you want them ignored entirely:
  # Remove: [-*]